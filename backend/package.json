{
  "name": "proxy-smart-backend",
  "displayName": "Proxy Smart Backend",
  "version": "0.0.5-beta.202604160334.ca7dae83",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "dev": "bun run --watch --watch-path src src/index.ts",
    "start": "bun run src/index.ts",
    "mcp": "bun run src/mcp-server.ts",
    "build": "tsc --noEmit && bun build src/index.ts --outdir dist --target node",
    "export-openapi": "mkdir -p dist && bun run src/export-openapi.ts && bun run scripts/sanitize-openapi.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "bun run typecheck && bun run lint"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.48",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/static": "^1.4.9",
    "@keycloak/keycloak-admin-client": "^26.6.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.48",
    "ai": "^6.0.158",
    "cross-fetch": "^4.1.0",
    "date-fns": "^4.1.0",
    "elysia": "^1.4.28",
    "fhirpath": "^4.9.3",
    "hl7.fhir.uv.ips-generated": "../apps/patient-portal/lib/hl7.fhir.uv.ips-generated.tgz",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "node-fetch": "^3.3.2",
    "node-forge": "^1.3.3",
    "pg": "^8.20.0",
    "unifi-access": "^1.5.3",
    "@opendataloader/pdf": "^2.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/bun": "^1.3.12",
    "@types/fhir": "^0.0.41",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-fetch": "^2.6.13",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.12",
    "eslint": "^10.1.0",
    "globals": "^17.5.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "module": "src/index.js"
}
