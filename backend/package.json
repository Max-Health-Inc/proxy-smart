{
  "name": "proxy-smart-backend",
  "displayName": "Proxy Smart Backend",
  "version": "0.0.2-alpha.202603220832.dfdc8a0b",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "dev": "bun run --watch --watch-path src src/index.ts",
    "start": "bun run src/index.ts",
    "mcp": "bun run src/mcp-server.ts",
    "build": "tsc --noEmit && bun build src/index.ts --outdir dist --target node",
    "export-openapi": "mkdir -p dist && bun run src/export-openapi.ts && bun run scripts/sanitize-openapi.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "bun run typecheck && bun run lint"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/static": "^1.4.7",
    "@keycloak/keycloak-admin-client": "^26.5.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.48",
    "ai": "^6.0.134",
    "cross-fetch": "^4.1.0",
    "elysia": "^1.4.28",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "node-fetch": "^3.3.2",
    "node-forge": "^1.3.3",
    "pg": "^8.20.0",
    "unifi-access": "^1.5.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/bun": "^1.3.11",
    "@types/fhir": "^0.0.41",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-fetch": "^2.6.13",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.11",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "module": "src/index.js"
}
