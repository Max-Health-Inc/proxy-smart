{
  "name": "proxy-smart-backend",
  "displayName": "Proxy Smart Backend",
  "version": "0.1.0-alpha.202605032340.faa198e5",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "dev": "bun run --watch --watch-path src src/index.ts",
    "start": "bun run src/index.ts",
    "mcp": "bun run src/mcp-server.ts",
    "build": "tsc --noEmit && bun build src/index.ts --outdir dist --target node --external undici --external node-fetch",
    "export-openapi": "mkdir -p dist && bun run src/export-openapi.ts && bun run scripts/sanitize-openapi.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "bun run typecheck && bun run lint"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.58",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/static": "^1.4.10",
    "@keycloak/keycloak-admin-client": "^26.6.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opendataloader/pdf": "^2.4.1",
    "@proxy-smart/auth": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "ai": "^6.0.174",
    "cross-fetch": "^4.1.0",
    "date-fns": "^4.1.0",
    "elysia": "^1.4.28",
    "fhirpath": "^4.10.0",
    "hl7.fhir.uv.ips-generated": "../lib/hl7.fhir.uv.ips-generated.tgz",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "kill-the-clipboard": "^1.1.0",
    "node-fetch": "^3.3.2",
    "node-forge": "^1.4.0",
    "pg": "^8.20.0",
    "resend": "^6.12.2",
    "unifi-access": "^1.5.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/bun": "^1.3.13",
    "@types/fhir": "^0.0.42",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-fetch": "^2.6.13",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.13",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "module": "src/index.js"
}
