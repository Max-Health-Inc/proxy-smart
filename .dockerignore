# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
**/dist/
build/
**/build/

# Development files
.env
**/.env
.env.local
.env.*.local
**/.env.local
**/.env.*.local

# Git
.git/
.gitignore
.gitattributes
.github/
.githooks/

# Documentation (keep docs/ for VitePress, keep prompts/ for AI)
docs/.vitepress/cache/
docs/.vitepress/dist/
# Exclude root-level markdown files only
/CHANGELOG.md
/CONTRIBUTING.md
/LICENSE-DUAL.md
/README.md

# Testing
testing/
**/tests/
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js
coverage/
**/coverage/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
logs/
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Keycloak (exclude everything except realm export files and themes)
keycloak/
!keycloak/realm-export*.json
!keycloak/themes/

# Agent (if not needed in production)
agent/
