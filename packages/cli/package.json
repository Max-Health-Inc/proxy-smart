{
  "name": "@proxy-smart/cli",
  "version": "0.2.13-beta.202606150124.4355ce961",
  "private": false,
  "type": "module",
  "description": "Admin CLI for the proxy-smart SMART on FHIR authorization proxy. Authenticates via Keycloak OAuth (device flow or client_credentials) and drives the admin REST API.",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Max-Health-Inc/proxy-smart.git",
    "directory": "packages/cli"
  },
  "license": "AGPL-3.0-or-later",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "proxy-smart": "./src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "generate": "openapi-ts-fetch ../../backend/dist/openapi.json ./src/api-client --tags smart-apps,healthcare-users,scope-sets,mcp-management,admin",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "bun-types": "^1.3.14",
    "typescript": "6.0.3"
  },
  "keywords": [
    "proxy-smart",
    "cli",
    "smart-on-fhir",
    "keycloak",
    "oauth2",
    "device-flow",
    "admin",
    "bun"
  ]
}
