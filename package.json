{
  "name": "proxy-smart",
  "version": "0.2.3-beta.202606010003.0daf4f5d7",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Max-Health-Inc/proxy-smart.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/fhir": "^0.0.43",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "babelfhir-ts": "^1.5.7",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "glob": "^13.0.6",
    "rollup": "^4.60.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitepress": "^1.6.4",
    "vue": "^3.5.35"
  },
  "description": "Proxy Smart - Healthcare interoperability proxy with Keycloak integration",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "keywords": [
    "proxy-smart",
    "healthcare",
    "keycloak",
    "oauth2",
    "fhir",
    "elysia",
    "react",
    "typescript"
  ],
  "license": "AGPL-3.0-or-later",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:ui\"",
    "dev:backend": "cd backend && bun run dev",
    "dev:ui": "cd frontend/ui && bun run dev",
    "dev:full": "bun run build:apps && bun run copy:apps-to-backend && cd backend && bun run dev",
    "copy:ui-to-backend": "node scripts/copy-ui-dist.js",
    "copy:apps-to-backend": "node scripts/copy-ui-dist.js",
    "build": "bun run build:backend && bun run build:ui",
    "build:backend": "cd backend && bun run build",
    "build:ui": "cd frontend/ui && bun run build",
    "build:full": "bun run build:apps && bun run copy:apps-to-backend && cd backend && bun run build",
    "build:ui:static": "cd frontend/ui && cross-env VITE_BASE=/webapp/ bun run build",
    "build:patient-picker:static": "cd packages/patient-picker && npx vite build --base /patient-picker/",
    "build:apps": "bun run build:ui:static && bun run build:patient-picker:static && bun run docs:build",
    "start": "concurrently \"bun run start:backend\" \"bun run start:ui\"",
    "start:backend": "cd backend && bun run start",
    "start:ui": "cd frontend/ui && bun run preview",
    "normalize": "git add --renormalize .",
    "normalize:api": "cd frontend/ui && git add --renormalize src/lib/api-client/",
    "generate": "cd backend && bun run export-openapi && cd .. && bun run generate:clients",
    "generate:clients": "cd frontend/ui && bun run generate",
    "generate:ui": "cd backend && bun run export-openapi && cd ../frontend/ui && bun run generate",
    "generate:ui:normalized": "bun run generate:ui && git add --renormalize frontend/ui/src/lib/api-client/",
    "generate:test": "cd testing && bun run generate",
    "validate-api": "concurrently \"bun run validate-api:ui\" \"bun run validate-api:test\"",
    "validate-api:ui": "cd frontend/ui && bun run validate-api",
    "validate-api:test": "cd testing && bun run validate-api",
    "test": "concurrently \"bun run test:backend\" \"bun run test:ui\"",
    "test:backend": "cd backend && bun run test",
    "test:ui": "cd frontend/ui && bun run test",
    "test:alpha": "cd testing/alpha && bun run test",
    "test:beta": "cd testing/beta && bun run test",
    "test:production": "cd testing/production && bun run test",
    "test:all": "bun run test:alpha && bun run test:beta && bun run test:production",
    "typecheck": "concurrently \"bun run typecheck:backend\" \"bun run typecheck:ui\"",
    "typecheck:backend": "cd backend && bun run typecheck",
    "typecheck:ui": "cd frontend/ui && bun run typecheck",
    "lint": "concurrently \"bun run lint:backend\" \"bun run lint:ui\" \"bun run lint:dicom\" \"bun run lint:infra\"",
    "lint:backend": "cd backend && bun run lint",
    "lint:ui": "cd frontend/ui && bun run lint",
    "lint:dicom": "cd frontend/smart-dicom-template && bun run lint",
    "lint:infra": "cd deploy/infra && bun run lint",
    "lint:fix": "concurrently \"bun run lint:fix:backend\" \"bun run lint:fix:ui\" \"bun run lint:fix:dicom\" \"bun run lint:fix:infra\"",
    "lint:fix:backend": "cd backend && bun run lint:fix",
    "lint:fix:ui": "cd frontend/ui && bun run lint:fix",
    "lint:fix:dicom": "cd frontend/smart-dicom-template && bun run lint:fix",
    "lint:fix:infra": "cd deploy/infra && bun run lint:fix",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "check": "bun run typecheck && bun run lint",
    "clean": "bun run clean:backend && bun run clean:ui",
    "clean:backend": "cd backend && rm -rf node_modules dist",
    "clean:ui": "cd frontend/ui && rm -rf node_modules dist",
    "docker:dev": "docker compose -f docker-compose.development.yml up -d",
    "docker:dev:build": "docker-compose -f docker-compose.development.yml up --build -d",
    "docker:dev:down": "docker-compose -f docker-compose.development.yml down",
    "docker:dev:logs": "docker-compose -f docker-compose.development.yml logs -f",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:build": "docker-compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker-compose -f docker-compose.prod.yml logs -f",
    "docker:backend": "docker build -t proxy-smart-backend --target backend .",
    "docker:mono": "docker build -t proxy-smart-mono .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "keycloak:start": "docker compose up -d keycloak",
    "keycloak:stop": "docker compose stop keycloak",
    "setup": "bun install && cd backend && bun install && cd ../frontend/ui && bun install && cd .. && node scripts/setup-hooks.js",
    "version:sync": "node scripts/version.js sync",
    "version:bump": "node scripts/version.js bump",
    "version:bump:minor": "node scripts/version.js bump minor",
    "version:bump:major": "node scripts/version.js bump major",
    "version:set": "node scripts/version.js set",
    "version:check": "node scripts/version.js check",
    "version:base": "node scripts/version.js base",
    "precommit": "bun run version:sync",
    "infra:synth": "cd deploy/infra && npx cdk synth",
    "infra:diff": "cd deploy/infra && npx cdk diff",
    "infra:deploy": "cd deploy/infra && npx cdk deploy --all",
    "infra:deploy:alpha": "cd deploy/infra && npx cdk deploy --all -c environment=alpha",
    "infra:deploy:beta": "cd deploy/infra && npx cdk deploy --all -c environment=beta",
    "infra:deploy:production": "cd deploy/infra && npx cdk deploy --all -c environment=production",
    "infra:destroy": "cd deploy/infra && npx cdk destroy --all",
    "infra:bootstrap": "cd deploy/infra && npx cdk bootstrap"
  },
  "type": "module",
  "workspaces": [
    "packages/auth",
    "packages/app-store",
    "config/eslint",
    "backend",
    "deploy/infra",
    "frontend/ui",
    "packages/patient-picker",
    "frontend/smart-dicom-template"
  ],
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs"
  },
  "author": "",
  "bugs": {
    "url": "https://github.com/Max-Health-Inc/proxy-smart/issues"
  },
  "homepage": "https://beta.proxy-smart.com",
  "dependencies": {
    "hl7.fhir.uv.smart-app-launch-generated": "./lib/hl7.fhir.uv.smart-app-launch-generated.tgz",
    "undici": "^8.3.0"
  },
  "overrides": {
    "zod": "4.3.6"
  },
  "resolutions": {
    "zod": "4.3.6"
  }
}
