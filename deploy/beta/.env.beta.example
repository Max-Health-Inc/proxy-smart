# Beta environment variables for docker-compose.beta.yml
# Copy to .env.beta and fill in real values before deploying.
#
# On the VPS, place this file at /opt/proxy-smart-beta/.env.beta
# Then run: docker compose -f docker-compose.beta.yml --env-file .env.beta up -d

# ─── Postgres ────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme-postgres
KC_DB_PASSWORD=changeme-postgres

# ─── Keycloak ────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=changeme-keycloak-admin

# ─── Backend ─────────────────────────────────────────────────────
KEYCLOAK_ADMIN_CLIENT_SECRET=changeme-admin-service-secret

# ─── Proxy Signing Key (stable RSA PEM for federated client auth) ─
# Generate: openssl genrsa -out proxy-signing-key.pem 2048
# Place the .pem file next to docker-compose.beta.yml (or set path below).
# If the file is missing, an ephemeral key is generated on every restart.
# PROXY_SIGNING_KEY_PATH=./proxy-signing-key.pem

# ─── AI Assistant (optional) ─────────────────────────────────────
# OPENAI_API_KEY=sk-proj-...

# ─── Email / SMTP (optional, enables forgot-password) ───────────
# RESEND_API_KEY=re_...

# ─── Frontend (baked into Vite build) ────────────────────────────
VITE_ENCRYPTION_SECRET=changeme-encryption-secret
