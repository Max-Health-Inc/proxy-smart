#!/bin/bash
set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Don't add [skip build] if it's already there
if echo "$COMMIT_MSG" | grep -qF "[skip build]"; then
  exit 0
fi

# Don't modify merge commits
if echo "$COMMIT_MSG" | head -1 | grep -qE "^Merge "; then
  exit 0
fi

# Append [skip build] so Northflank only builds on CI version-bump commits
echo "" >> "$COMMIT_MSG_FILE"
echo "[skip build]" >> "$COMMIT_MSG_FILE"

exit 0
