#!/bin/bash
set -euo pipefail

echo "Auto-rebasing before push..."

if ! git pull --rebase --autostash --quiet; then
  echo "❌ Auto-rebase failed (likely conflicts). Please resolve them manually (git status), then re-push."
  exit 1
fi

echo "✅ Up to date with remote"

# After rebase, version strings in package.json files may be out of sync
# (rebase conflict resolution can leave stale version stamps). Re-sync
# and amend the latest commit if anything changed.
node scripts/version.js sync
if ! git diff --quiet; then
  echo "⚠️  Version drift detected after rebase — syncing..."
  git add -u
  git commit --amend --no-edit --no-verify
  echo "✅ Versions re-synced"
fi

exit 0
