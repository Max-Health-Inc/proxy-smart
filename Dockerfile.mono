# Multi-stage build for Proxy Smart monorepo - Mono Mode
FROM oven/bun:slim AS base
WORKDIR /app

# Build stage
FROM base AS build
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
    build-essential \
    pkg-config \
    python-is-python3 \
    openjdk-21-jre-headless \
    && rm -rf /var/lib/apt/lists/*

# ── Dependency install layer (cached unless package.json/bun.lock/tgz change) ──
COPY package.json bun.lock ./
COPY lib/ ./lib/
COPY backend/package.json ./backend/
COPY shared-ui/package.json ./shared-ui/
COPY apps/ui/package.json ./apps/ui/
COPY apps/dtr-app/package.json ./apps/dtr-app/
COPY apps/dtr-app/lib/ ./apps/dtr-app/lib/
COPY apps/consent-app/package.json ./apps/consent-app/
COPY apps/consent-app/lib/ ./apps/consent-app/lib/
COPY apps/patient-portal/package.json ./apps/patient-portal/
COPY apps/patient-portal/lib/ ./apps/patient-portal/lib/
COPY infra/package.json ./infra/
COPY scripts/package.json ./scripts/

# Strip workspaces not included in the mono build to avoid install failures
RUN bun -e 'const p=JSON.parse(require("fs").readFileSync("./package.json","utf8")); p.workspaces=["backend","apps/ui","shared-ui","apps/consent-app","apps/dtr-app","apps/patient-portal"]; require("fs").writeFileSync("./package.json", JSON.stringify(p,null,2))'

# Install dependencies (this layer is cached when only source code changes)
RUN bun install

# ── Source copy (changes frequently, but bun install is already cached) ──
COPY backend/ ./backend/
COPY shared-ui/ ./shared-ui/
COPY apps/ui/ ./apps/ui/
COPY apps/dtr-app/ ./apps/dtr-app/
COPY apps/consent-app/ ./apps/consent-app/
COPY apps/patient-portal/ ./apps/patient-portal/
COPY infra/ ./infra/
COPY scripts/ ./scripts/
COPY docs/ ./docs/

# Encryption secret for browser local-storage obfuscation (baked into Vite bundle)
ARG VITE_ENCRYPTION_SECRET=proxy-smart-default-encryption-key
ENV VITE_ENCRYPTION_SECRET=${VITE_ENCRYPTION_SECRET}

RUN bun run generate:ui
# Use the mono build script which handles:
# - Building UI with correct VITE_BASE=/webapp/
# - Copying UI dist to backend/public/webapp/
# - Building backend
RUN bun run build:mono

# Verify no localhost URLs leaked into production bundles via .env files
RUN if grep -rl 'localhost:8445' /app/backend/public/apps/ 2>/dev/null; then \
      echo "ERROR: Found hardcoded localhost:8445 in app bundles. Check .dockerignore excludes .env files." && exit 1; \
    fi

# Production stage - backend API server with static frontend
FROM base AS production
WORKDIR /app

# Install minimal runtime dependencies
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy built backend
COPY --from=build /app/backend/dist ./backend/dist
COPY --from=build /app/backend/package.json ./backend/package.json
COPY --from=build /app/backend/mcp-server-templates.json ./backend/mcp-server-templates.json

# Copy backend's public directory (contains the copied UI)
COPY --from=build /app/backend/public ./backend/public

# Copy root node_modules (monorepo structure)
COPY --from=build /app/node_modules ./node_modules

# Copy raw markdown docs for the /docs API
COPY --from=build /app/docs ./docs

# Copy system prompt for AI assistant
COPY prompts/ ./prompts/

# Expose backend port
EXPOSE 8445

# Start the backend (which serves the UI static files from /public)
WORKDIR /app/backend
CMD ["bun", "run", "dist/index.js"]
